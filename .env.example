# Tester roster collector (Formspree). Create a free form at formspree.io,
# then paste its endpoint here in a .env file (not committed) and redeploy.
# Names POST here on each tester's first launch so you can count who's testing.
EXPO_PUBLIC_TESTER_ENDPOINT=

# Supabase (Track B — real accounts + cross-device progress sync). Empty = offline-first local-only.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
